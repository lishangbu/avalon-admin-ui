{
  "name": "avalon-admin-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run typecheck && npm run build:bundle",
    "build:bundle": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:game-data": "vitest run src/pages/game-data src/services/game-data.test.ts",
    "test:battle-ui": "vitest run src/pages/battle-rules src/pages/battle-sandbox src/services/battle-rules.test.ts src/services/battle-rule-options.test.ts src/services/battle-sandbox.test.ts",
    "test:smoke:menu": "playwright test e2e/menu-smoke.spec.ts --project=chromium",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build:bundle && npm run test:smoke:menu",
    "test:watch": "vitest",
    "openapi:pull": "node scripts/pull-openapi.mjs",
    "openapi:generate": "openapi-typescript src/services/generated/openapi.json -o src/services/generated/schema.d.ts",
    "openapi:sync": "npm run openapi:pull && npm run openapi:generate && prettier --write src/services/generated/openapi.json src/services/generated/schema.d.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/icons": "6.2.5",
    "@ant-design/pro-components": "3.1.12-0",
    "@tanstack/react-query": "5.101.1",
    "antd": "6.4.5",
    "dayjs": "1.11.21",
    "openapi-fetch": "0.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@iconify-json/lucide": "1.2.114",
    "@iconify/tailwind4": "1.2.3",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.5.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
